# OpenInsure Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Application
OPENINSURE_DEBUG=false
OPENINSURE_LOG_LEVEL=INFO

# Authentication
OPENINSURE_API_KEY=change-me-to-a-secure-random-string
OPENINSURE_REQUIRE_AUTH=false

# CORS (comma-separated origins for production)
OPENINSURE_CORS_ORIGINS=https://your-dashboard.example.com

# Azure SQL Database
OPENINSURE_SQL_CONNECTION_STRING=
OPENINSURE_SQL_DATABASE_NAME=openinsure

# Azure Cosmos DB (Gremlin API)
OPENINSURE_COSMOS_ENDPOINT=
OPENINSURE_COSMOS_DATABASE_NAME=openinsure-knowledge
OPENINSURE_COSMOS_GRAPH_NAME=insurance-graph

# Azure AI Search
OPENINSURE_SEARCH_ENDPOINT=
OPENINSURE_SEARCH_INDEX_NAME=openinsure-knowledge

# Azure Blob Storage
OPENINSURE_STORAGE_ACCOUNT_URL=
OPENINSURE_STORAGE_CONTAINER_NAME=documents

# Azure Event Grid / Service Bus
OPENINSURE_EVENTGRID_ENDPOINT=
OPENINSURE_SERVICEBUS_CONNECTION_STRING=
OPENINSURE_SERVICEBUS_QUEUE_NAME=openinsure-events

# Azure AI / Foundry
OPENINSURE_FOUNDRY_PROJECT_ENDPOINT=
OPENINSURE_FOUNDRY_MODEL_DEPLOYMENT=gpt-5.2

# Server
OPENINSURE_HOST=0.0.0.0
OPENINSURE_PORT=8000
OPENINSURE_WORKERS=4
