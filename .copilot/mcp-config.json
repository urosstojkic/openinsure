{
  "mcpServers": {
    "openinsure": {
      "command": "python",
      "args": ["-m", "openinsure.mcp"],
      "env": {
        "OPENINSURE_API_BASE_URL": "https://your-backend.swedencentral.azurecontainerapps.io"
      }
    },
    "EXAMPLE-github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
